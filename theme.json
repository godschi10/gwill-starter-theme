{
  "$schema": "https://schemas.wp.org/wp/6.6/theme.json",
  "version": 2,
  "settings": {
    "useRootPaddingAwareAlignments": true,
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#111111",
          "name": "Primary",
          "slug": "primary"
        },
        {
          "color": "#2563eb",
          "name": "Accent",
          "slug": "accent"
        },
        {
          "color": "#ffffff",
          "name": "White",
          "slug": "white"
        },
        {
          "color": "#6b7280",
          "name": "Muted",
          "slug": "muted"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "dropCap": false
    },
    "spacing": {
      "customSpacingSize": false
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    }
  },
  "styles": {
    "typography": {
      "fontSize": "1rem",
      "lineHeight": "1.6",
      "fontFamily": "system-ui, -apple-system, sans-serif"
    },
    "color": {
      "text": "#111111",
      "background": "#ffffff"
    },
    "elements": {
      "link": {
        "color": {
          "text": "#2563eb"
        },
        ":hover": {
          "color": {
            "text": "#1d4ed8"
          },
          "typography": {
            "textDecoration": "underline"
          }
        },
        "typography": {
          "textDecoration": "none"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "clamp(1.75rem, 4vw, 2.5rem)",
          "lineHeight": "1.2",
          "fontWeight": "700"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "clamp(1.4rem, 3vw, 2rem)",
          "lineHeight": "1.25",
          "fontWeight": "700"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "clamp(1.15rem, 2.5vw, 1.5rem)",
          "lineHeight": "1.3",
          "fontWeight": "600"
        }
      },
      "heading": {
        "color": {
          "text": "#111111"
        }
      },
      "button": {
        "color": {
          "text": "#ffffff",
          "background": "#2563eb"
        },
        "typography": {
          "fontWeight": "600"
        },
        ":hover": {
          "color": {
            "background": "#1d4ed8"
          }
        }
      },
      "h4": {
        "typography": {
          "fontSize": "clamp(1.05rem, 2vw, 1.25rem)",
          "lineHeight": "1.35",
          "fontWeight": "600"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "clamp(1rem, 1.5vw, 1.1rem)",
          "lineHeight": "1.4",
          "fontWeight": "600"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "1rem",
          "lineHeight": "1.4",
          "fontWeight": "600",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        }
      }
    }
  }
}
