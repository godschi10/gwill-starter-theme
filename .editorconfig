root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.php]
indent_style = tab

[*.{css,js,json,yml,yaml}]
indent_style = space
indent_size = 2

# Two trailing spaces at the end of a Markdown line produce a <br> in
# rendered output — trimming them silently breaks line breaks in docs.
[*.md]
trim_trailing_whitespace = false
